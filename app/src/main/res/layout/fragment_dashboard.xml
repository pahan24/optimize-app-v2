<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/neon_blue"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_device_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_app_title"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_device_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Device: Loading..."
                    android:textColor="@color/text_primary"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tv_android_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Android: Loading..."
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tv_cpu_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="CPU: Loading..."
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tv_storage_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Storage: Loading..."
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tv_root_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Root Access: Checking..."
                    android:textColor="@color/accent_red"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="24dp"
            app:layout_constraintTop_toBottomOf="@id/card_device_info"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="System Performance"
                        android:textColor="@color/text_white"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tv_overall_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="EXCELLENT"
                        android:textColor="@color/accent_green"
                        android:textStyle="bold" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/progress_ram_circular"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            app:indicatorColor="@color/neon_blue"
                            app:indicatorSize="80dp"
                            app:trackColor="@color/bg_dark"
                            app:trackCornerRadius="4dp"
                            app:trackThickness="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RAM"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_ram_value_dashboard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="0%"
                            android:textColor="@color/text_white" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/progress_cpu_circular"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            app:indicatorColor="@color/accent_red"
                            app:indicatorSize="80dp"
                            app:trackColor="@color/bg_dark"
                            app:trackCornerRadius="4dp"
                            app:trackThickness="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CPU"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_cpu_value_dashboard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="0%"
                            android:textColor="@color/text_white" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/progress_temp_circular"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            app:indicatorColor="@color/accent_orange"
                            app:indicatorSize="80dp"
                            app:trackColor="@color/bg_dark"
                            app:trackCornerRadius="4dp"
                            app:trackThickness="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TEMP"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_temp_value_dashboard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="0°C"
                            android:textColor="@color/text_white" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="@color/bg_dark" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Network Ping"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_ping_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="24ms"
                            android:textColor="@color/accent_green"
                            android:textSize="18sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Battery Current"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_battery_current"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="-240mA"
                            android:textColor="@color/neon_blue"
                            android:textSize="18sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_boost"
            style="@style/NeonButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/boost"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/card_stats" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:columnCount="2"
            app:layout_constraintTop_toBottomOf="@id/btn_boost">

            <!-- Row 1 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_game_boost"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@android:drawable/ic_menu_compass" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/game_boost" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_cpu_control"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@android:drawable/ic_menu_manage" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/cpu_control" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_storage_cleaner"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@android:drawable/ic_menu_delete" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/storage_cleaner" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Row 2 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_thermal_control"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@android:drawable/ic_menu_info_details" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/thermal_control" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_battery_saver"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@android:drawable/ic_lock_idle_low_battery" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/battery_saver" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_app_manager"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@android:drawable/ic_menu_sort_by_size" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/app_manager" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Row 3 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_network_optimizer"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@android:drawable/presence_online" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/network_optimizer" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_display_tweaks"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@android:drawable/ic_menu_gallery" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/display_tweaks" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_kernel_tweaks"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@android:drawable/ic_menu_preferences" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/kernel_tweaks" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Row 4 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_system_debloater"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@android:drawable/ic_menu_close_clear_cancel" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/system_debloater" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_dns_changer"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@android:drawable/ic_menu_share" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/dns_changer" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_charging_booster"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@android:drawable/ic_lock_power_off" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/charging_booster" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Row 5 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_auto_clean"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@android:drawable/ic_menu_recent_history" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/auto_clean" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_fps_meter"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@drawable/ic_zap" />
                    <TextView style="@style/FeatureTextStyle" android:text="FPS Meter" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_lag_fixer"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@android:drawable/ic_menu_send" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/lag_fixer" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_free_fire"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <androidx.appcompat.widget.AppCompatImageView style="@style/FeatureIconStyle" android:src="@android:drawable/ic_menu_compass" app:tint="@color/accent_red" />
                    <TextView style="@style/FeatureTextStyle" android:text="Free Fire" android:textColor="@color/accent_red" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_game_tools"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@android:drawable/ic_menu_view" />
                    <TextView style="@style/FeatureTextStyle" android:text="Game Tools" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_settings"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@android:drawable/ic_menu_set_as" />
                    <TextView style="@style/FeatureTextStyle" android:text="Settings" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
