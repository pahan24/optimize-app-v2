<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg">

    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_glow_blue"
        app:layout_constraintEnd_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="-100dp"
        android:layout_marginEnd="-100dp"
        android:alpha="0.05" />

    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_glow_red"
        app:layout_constraintStart_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="-100dp"
        android:layout_marginStart="-100dp"
        android:alpha="0.05" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

        <RelativeLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:cardBackgroundColor="#103B82F6"
                    app:cardCornerRadius="12dp"
                    app:strokeColor="#203B82F6"
                    app:strokeWidth="1dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_zap"
                        app:tint="@color/neon_blue" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_app_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="ULTRA\nOPTIMIZE X"
                        android:textColor="@color/text_white"
                        android:textSize="20sp"
                        android:lineSpacingMultiplier="0.9"
                        android:letterSpacing="-0.02" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="SYSTEM CALIBRATION SUITE"
                        android:textColor="#603B82F6"
                        android:textSize="8sp"
                        android:letterSpacing="0.2" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_theme_toggle"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="#10FFFFFF"
                    app:cardCornerRadius="12dp"
                    app:strokeColor="#20FFFFFF"
                    app:strokeWidth="1dp">
                    <ImageView
                        android:id="@+id/iv_theme_icon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_sun"
                        app:tint="@color/text_secondary" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_settings_header"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:cardBackgroundColor="#10FFFFFF"
                    app:cardCornerRadius="12dp"
                    app:strokeColor="#20FFFFFF"
                    app:strokeWidth="1dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_settings"
                        app:tint="@color/text_secondary" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </RelativeLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_device_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="16dp"
            app:layout_constraintTop_toBottomOf="@id/header"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/neon_blue"
                    android:alpha="0.5" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:id="@+id/iv_device_icon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_smartphone"
                            app:tint="@color/neon_blue" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_toEndOf="@id/iv_device_icon"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-black"
                                android:text="DEVICE MODEL"
                                android:textColor="@color/text_secondary"
                                android:textSize="8sp"
                                android:letterSpacing="0.2" />

                            <TextView
                                android:id="@+id/tv_device_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-black"
                                android:text="Samsung Galaxy S24 Ultra"
                                android:textColor="@color/text_white"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/shape_circle"
                            android:backgroundTint="#10B981"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:text="SECURE"
                            android:textColor="@color/white"
                            android:textSize="8sp"
                            android:fontFamily="sans-serif-black" />
                    </RelativeLayout>

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-black"
                                android:text="OS VERSION"
                                android:textColor="@color/text_secondary"
                                android:textSize="8sp"
                                android:letterSpacing="0.2" />

                            <TextView
                                android:id="@+id/tv_android_version"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="Android 14 (API 34)"
                                android:textColor="@color/text_primary"
                                android:textSize="10sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-black"
                                android:text="STORAGE STATUS"
                                android:textColor="@color/text_secondary"
                                android:textSize="8sp"
                                android:letterSpacing="0.2" />

                            <TextView
                                android:id="@+id/tv_storage_info"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="412 GB / 512 GB"
                                android:textColor="@color/text_primary"
                                android:textSize="10sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-black"
                                android:text="PROCESSOR"
                                android:textColor="@color/text_secondary"
                                android:textSize="8sp"
                                android:letterSpacing="0.2" />

                            <TextView
                                android:id="@+id/tv_cpu_info"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="Snapdragon 8 Gen 3"
                                android:textColor="@color/text_primary"
                                android:textSize="10sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-black"
                                android:text="ROOT ACCESS"
                                android:textColor="@color/text_secondary"
                                android:textSize="8sp"
                                android:letterSpacing="0.2" />

                            <TextView
                                android:id="@+id/tv_root_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-black"
                                android:text="AUTHORIZED"
                                android:textColor="@color/accent_green"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </GridLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="24dp"
            app:layout_constraintTop_toBottomOf="@id/card_device_info"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/system_health"
                        android:textColor="@color/text_white"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tv_overall_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="@string/optimal_state"
                        android:textColor="@color/accent_green"
                        android:textStyle="bold" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/progress_ram_circular"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            app:indicatorColor="@color/neon_blue"
                            app:indicatorSize="80dp"
                            app:trackColor="@color/bg_dark"
                            app:trackCornerRadius="4dp"
                            app:trackThickness="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RAM"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_ram_value_dashboard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="0%"
                            android:textColor="@color/text_white" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/progress_cpu_circular"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            app:indicatorColor="#3B82F6"
                            app:indicatorSize="80dp"
                            app:trackColor="@color/bg_dark"
                            app:trackCornerRadius="4dp"
                            app:trackThickness="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/processor"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_cpu_value_dashboard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="0%"
                            android:textColor="@color/text_white" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/progress_temp_circular"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            app:indicatorColor="@color/accent_orange"
                            app:indicatorSize="80dp"
                            app:trackColor="@color/bg_dark"
                            app:trackCornerRadius="4dp"
                            app:trackThickness="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/thermal_label"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_temp_value_dashboard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="0°C"
                            android:textColor="@color/text_white" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="@color/bg_dark" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/latency"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_ping_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="24ms"
                            android:textColor="@color/accent_green"
                            android:textSize="18sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/discharge"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_battery_current"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="-240mA"
                            android:textColor="@color/neon_blue"
                            android:textSize="18sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_boost"
            style="@style/NeonButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="24dp"
            android:text="@string/boost"
            android:textSize="18sp"
            app:icon="@drawable/ic_zap"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconSize="24dp"
            app:iconTint="@color/text_white"
            app:elevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/card_stats" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:columnCount="2"
            app:layout_constraintTop_toBottomOf="@id/btn_boost">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_game_boost"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@drawable/ic_zap" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/game_boost" />
                    <TextView style="@style/FeatureSubtitleStyle" android:text="@string/ram_cleaner_sub" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_cpu_control"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@drawable/ic_cpu" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/cpu_control" />
                    <TextView style="@style/FeatureSubtitleStyle" android:text="@string/cpu_cooler_sub" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_storage_cleaner"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@drawable/ic_trash" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/storage_cleaner" />
                    <TextView style="@style/FeatureSubtitleStyle" android:text="@string/storage_manager_sub" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Row 2 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_thermal_control"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@drawable/ic_thermometer" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/thermal_control" />
                    <TextView style="@style/FeatureSubtitleStyle" android:text="@string/running_smooth" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_battery_saver"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@drawable/ic_battery" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/battery_saver" />
                    <TextView style="@style/FeatureSubtitleStyle" android:text="@string/battery_saver_sub" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_app_manager"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@drawable/ic_layers" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/app_manager" />
                    <TextView style="@style/FeatureSubtitleStyle" android:text="@string/optimization_active" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Row 3 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_network_optimizer"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@drawable/ic_wifi" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/network_optimizer" />
                    <TextView style="@style/FeatureSubtitleStyle" android:text="@string/optimization_active" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_display_tweaks"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@drawable/ic_monitor" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/display_tweaks" />
                    <TextView style="@style/FeatureSubtitleStyle" android:text="@string/running_smooth" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_kernel_tweaks"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@drawable/ic_settings_2" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/kernel_tweaks" />
                    <TextView style="@style/FeatureSubtitleStyle" android:text="@string/system_optimized" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Row 4 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_system_debloater"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@drawable/ic_shield_off" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/system_debloater" />
                    <TextView style="@style/FeatureSubtitleStyle" android:text="@string/system_optimized" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_dns_changer"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@drawable/ic_globe" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/dns_changer" />
                    <TextView style="@style/FeatureSubtitleStyle" android:text="@string/optimization_active" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_charging_booster"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@drawable/ic_zap" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/charging_booster" />
                    <TextView style="@style/FeatureSubtitleStyle" android:text="@string/protection_on" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Row 5 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_auto_clean"
                style="@style/FeatureCardStyle">
                <LinearLayout style="@style/FeatureContentStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@drawable/ic_clock" />
                    <TextView style="@style/FeatureTextStyle" android:text="@string/auto_clean" />
                    <TextView style="@style/FeatureSubtitleStyle" android:text="@string/system_optimized" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

