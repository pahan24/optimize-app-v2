<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="32dp">

    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_glow_blue"
        app:layout_constraintEnd_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="-100dp"
        android:layout_marginEnd="-100dp"
        android:alpha="0.05" />

    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_glow_red"
        app:layout_constraintStart_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="-100dp"
        android:layout_marginStart="-100dp"
        android:alpha="0.05" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:elevation="10dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cv_logo"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="32dp"
            app:cardBackgroundColor="@color/neon_blue"
            app:cardCornerRadius="24dp"
            app:cardElevation="20dp"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/iv_logo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_zap"
                app:tint="@color/white" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:text="ULTRA\nOPTIMIZE X"
            android:textColor="@color/text_white"
            android:textSize="40sp"
            android:lineSpacingMultiplier="0.9"
            android:letterSpacing="-0.02" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="48dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="Professional-grade system calibration suite for advanced Android users."
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.2" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_username"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Username"
            app:boxStrokeColor="@color/neon_blue"
            app:hintTextColor="@color/neon_blue"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusTopStart="16dp"
            app:startIconDrawable="@drawable/ic_user"
            app:startIconTint="@color/neon_blue">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_username"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@color/text_white"
                android:fontFamily="sans-serif-medium" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_password"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:hint="6-Digit OTP"
            app:boxStrokeColor="@color/neon_blue"
            app:hintTextColor="@color/neon_blue"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="@color/neon_blue"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusTopStart="16dp"
            app:startIconDrawable="@drawable/ic_shield"
            app:startIconTint="@color/neon_blue">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberPassword"
                android:maxLength="6"
                android:textColor="@color/text_white"
                android:fontFamily="sans-serif-medium" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_login"
            style="@style/NeonButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="AUTHENTICATE"
            android:textSize="16sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_admin_login"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="ADMIN ACCESS"
            android:textColor="@color/text_white"
            app:strokeColor="@color/card_bg"
            app:icon="@drawable/ic_shield"
            app:iconGravity="textStart"
            app:iconTint="@color/neon_blue"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:gravity="center"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="500K+"
                    android:textColor="@color/text_white"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACTIVE USERS"
                    android:textColor="@color/text_muted"
                    android:textSize="8sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.1" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:layout_marginHorizontal="24dp"
                android:background="@color/card_bg" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4.9/5"
                    android:textColor="@color/text_white"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="USER RATING"
                    android:textColor="@color/text_muted"
                    android:textSize="8sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.1" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="SECURE OTP AUTHENTICATION"
            android:textColor="@color/text_muted"
            android:textSize="9sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.2" />

        <ProgressBar
            android:id="@+id/progress_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
