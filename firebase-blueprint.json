{
  "entities": {
    "OTP": {
      "title": "One-Time Password",
      "description": "A password that can only be used once for authentication.",
      "type": "object",
      "properties": {
        "isUsed": {
          "type": "boolean",
          "description": "Whether the password has already been used."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the password was generated."
        }
      },
      "required": ["isUsed", "createdAt"]
    }
  },
  "firestore": {
    "/otps/{otpId}": {
      "schema": "OTP",
      "description": "Collection of one-time passwords."
    }
  }
}
