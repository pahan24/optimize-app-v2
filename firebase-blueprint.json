{
  "entities": {
    "OTP": {
      "title": "One-Time Password",
      "description": "A password that can only be used once for authentication.",
      "type": "object",
      "properties": {
        "isUsed": {
          "type": "boolean",
          "description": "Whether the password has already been used."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the password was generated."
        }
      },
      "required": ["isUsed", "createdAt"]
    },
    "Session": {
      "title": "User Session",
      "description": "Represents an active or expired user session.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "expired"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "username", "status", "createdAt"]
    }
  },
  "firestore": {
    "/otps/{otpId}": {
      "schema": "OTP",
      "description": "Collection of one-time passwords."
    },
    "/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Collection of user sessions for remote management."
    }
  }
}
