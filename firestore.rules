rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is the admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "sasmikarashmika49@gmail.com" && request.auth.token.email_verified == true;
    }

    // OTP validation
    match /otps/{otpId} {
      // Users can 'get' an OTP to check if it's valid
      allow get: if true; 
      
      // Users can 'update' an OTP to mark it as used
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isUsed'])
                    && request.resource.data.isUsed == true
                    && resource.data.isUsed == false;

      // Admin can manage OTPs
      allow read, write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
