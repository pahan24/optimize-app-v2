rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is the admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email_verified == true &&
             request.auth.token.email == "bpahan685@gmail.com";
    }

    // OTP validation
    match /otps/{otpId} {
      // Users can 'get' an OTP to check if it's valid
      allow get: if true; 
      
      // Users can 'update' an OTP to mark it as used
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isUsed'])
                    && request.resource.data.isUsed == true
                    && resource.data.isUsed == false;

      // Admin can manage OTPs
      allow read, write: if isAdmin();
    }

    // Session management
    match /sessions/{sessionId} {
      // Allow anyone to create a session (during login)
      allow create: if true;
      
      // Allow reading a session if you know the ID
      allow get: if true;
      
      // Allow admins to list and manage all sessions
      allow list: if isAdmin();
      allow update: if isAdmin() || (
        // Allow the user to update their own session status to 'expired'
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status == 'expired'
      );
      
      // Allow delete for admin
      allow delete: if isAdmin();
    }

    // App Config
    match /app_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin authorization check
    match /admins/{email} {
      // Allow a user to check if their own email is in the admin list
      allow get: if request.auth != null && request.auth.token.email == email;
      allow read, write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
